# Copy to .env (not committed) or export in the shell before running.
# Oracle Easy Connect: host:port/service_name
# See: https://www.oracle.com/database/technologies/instant-client.html

ORACLE_USER=your_db_user
ORACLE_CONNECT_STRING=oracle.example.invalid:1521/ORCL
ORACLE_PASSWORD=

# Optional: numeric row in CORE.cosetting (default 681 if unset)
# COSETTING_ROW_ID=681
